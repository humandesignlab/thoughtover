# Vision, the "seeing": Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash        # verified current (gemini-2.5-flash is deprecated, shutdown 2026-10-16); 3-series handles video+audio well
GEMINI_VIDEO_FPS=4                   # raise above 1 so fast descents keep detail; 1 is the API default

# Writing, the persona: Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8      # or a Sonnet model for cheaper, faster drafts

# Voice, the speaking: ElevenLabs cloned voice
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=                 # your cloned voice id
ELEVENLABS_MODEL=eleven_multilingual_v2   # verify the current TTS model id in the ElevenLabs docs
NARRATION_SPEED=1.0                  # voice speed; 1.0 normal, >1 faster (mirrors the Speed slider)
NARRATION_STABILITY=0.5              # 0..1; higher is steadier/more monotone (Stability slider)
NARRATION_SIMILARITY=0.75            # 0..1; adherence to the cloned voice (Similarity slider)
NARRATION_STYLE=0.0                  # 0..1; style exaggeration (Style slider)
NARRATION_SPEAKER_BOOST=true         # boost similarity to the source speaker (Speaker boost)

# Output and mixing
NARRATION_DUCK_DB=-8                 # how much to lower the trail audio under each narration line; gentler keeps ambiance present
NARRATION_GAIN_DB=0                  # narration level; negative sits the voice into the mix instead of on top
NARRATION_REACTION_LAG=0.8           # seconds to delay each line after its beat, so it reads as reacting, not narrating
NARRATION_DUCK_FADE=0.4              # seconds to ease the trail down/back around each line, so the background doesn't jump

# Note: model ids move. Confirm each against the provider's current docs before relying on it.
